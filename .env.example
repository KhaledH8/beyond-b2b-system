# Copy to .env and fill in values for local development.
# Never commit .env — it is in .gitignore.

# --- Postgres (matches docker-compose.yml defaults) ---
DATABASE_URL=postgresql://bb:bb_local@localhost:5432/beyond_borders

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO local) ---
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=beyond-borders-local
OBJECT_STORAGE_ACCESS_KEY=bb_local
OBJECT_STORAGE_SECRET_KEY=bb_local_secret

# --- API ---
PORT=3000
NODE_ENV=development

# --- Worker ---
WORKER_PORT=3001

# --- Hotelbeds adapter ---
# Client kind: stub (default — throws NotImplemented), fixture (replays
# JSON files), live (real HTTP). Booking guard refuses every rate from
# every kind until ops swaps the money-movement resolver.
HOTELBEDS_CLIENT_KIND=stub
# Required when HOTELBEDS_CLIENT_KIND=live. Test creds from the
# Hotelbeds developer portal; rotate via that portal, never inline.
HOTELBEDS_API_KEY=
HOTELBEDS_API_SECRET=
HOTELBEDS_BASE_URL=https://api.test.hotelbeds.com
HOTELBEDS_REQUEST_TIMEOUT_MS=15000
HOTELBEDS_MAX_RETRIES=3
HOTELBEDS_RETRY_BASE_DELAY_MS=200
# When set, every successful live response is also written to disk.
# Files are sha256-named JSON; promote one into
# packages/testing/src/hotelbeds/fixtures/ to extend the conformance suite.
HOTELBEDS_CAPTURE_DIR=
# Required when HOTELBEDS_CLIENT_KIND=fixture. Directory containing
# hotels-page-01.json + availability-01.json.
HOTELBEDS_FIXTURE_DIR=
