{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "outDir": "dist",
    "rootDir": "src",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@bb/domain": [
        "../../packages/domain/src/index.ts"
      ],
      "@bb/config": [
        "../../packages/config/dist"
      ],
      "@bb/db": [
        "../../packages/db/dist"
      ],
      "@bb/supplier-contract": [
        "../../packages/supplier-contract/dist"
      ],
      "@bb/adapter-hotelbeds": [
        "../../packages/adapters/hotelbeds/dist"
      ],
      "@bb/testing": [
        "../../packages/testing/dist"
      ]
    }
  },
  "references": [
    {
      "path": "../../packages/domain"
    },
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/db"
    },
    {
      "path": "../../packages/supplier-contract"
    },
    {
      "path": "../../packages/adapters/hotelbeds"
    },
    {
      "path": "../../packages/testing"
    }
  ],
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
