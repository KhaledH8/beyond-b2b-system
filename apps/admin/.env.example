# ──────────────────────────────────────────────────────────────────────
# apps/admin — environment variables (ADR-029 D8)
# ──────────────────────────────────────────────────────────────────────
#
# Copy this file to `.env.local` and fill in real values from your
# local Auth0 dev tenant. NEVER commit `.env.local` or any other
# file matching `.env*` (the root `.gitignore` blocks all `.env*`
# except `.env.example`).
#
# The admin app is operator-only. There is no dev-token bypass.
# Local development requires a real Auth0 dev tenant (ADR-029 D11/D12).
#
# Variable names below follow `@auth0/nextjs-auth0` v4 conventions
# (verified against the SDK's V4 migration guide on 2026-05-10).
# This deviates from the names listed in ADR-029 D8 — see
# `apps/admin/README.md` § "Auth0 SDK route + env-name verification"
# for the resolution.

# ── Auth0 (required) ──────────────────────────────────────────────────

# Cookie encryption + signing key. Generate with:
#   openssl rand -hex 32
# 32+ random bytes (hex / base64 both fine). Rotate when compromised.
AUTH0_SECRET=replace-with-32-byte-random-hex

# This admin app's public URL. In v4 of @auth0/nextjs-auth0 this
# is named APP_BASE_URL (the v3 name was AUTH0_BASE_URL).
APP_BASE_URL=http://localhost:3012

# Auth0 tenant domain — hostname only, no scheme, no trailing slash.
# In v4 this is named AUTH0_DOMAIN (the v3 name was
# AUTH0_ISSUER_BASE_URL and required `https://` + trailing slash).
AUTH0_DOMAIN=your-dev-tenant.eu.auth0.com

# Auth0 application client id.
AUTH0_CLIENT_ID=replace-with-auth0-client-id

# Auth0 application client secret. Treat as production-grade secret
# even in dev. Share via the team password manager only.
AUTH0_CLIENT_SECRET=replace-with-auth0-client-secret

# Backend API audience (matches `aud` claim issued by Auth0 for our
# API). Same value the API uses for AUTH0_AUDIENCE.
AUTH0_AUDIENCE=https://api.beyondborders.platform

# OIDC scopes. ADR-029 D8 deliberately omits `offline_access` —
# V0.1 does not request refresh tokens. If you find yourself
# tempted to add it, write the ADR amendment first.
AUTH0_SCOPE=openid profile email

# ── Beyond Borders backend (required) ─────────────────────────────────

# URL of the @bb/api deployment this admin instance talks to.
BB_API_BASE_URL=http://localhost:3000

# The single tenant this admin deployment serves (ADR-029 D8).
# 26-char Crockford base32 ULID. Multi-tenant admin = future ADR.
BB_TENANT_ID=01ARZ3NDEKTSV4RRFFQ69G5FAV
