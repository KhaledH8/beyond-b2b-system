{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node10",
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,
    "paths": {
      "@bb/domain": ["../domain/src/index.ts"],
      "@bb/ledger": ["../ledger/src/index.ts"]
    }
  },
  "references": [{ "path": "../domain" }, { "path": "../ledger" }],
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
